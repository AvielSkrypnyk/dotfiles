# ----------------------------------
# Reload
# ----------------------------------

alt + shift + o : komorebic reload-configuration

# ----------------------------------
# Focus Windows
# cmd + ctrl + arrows
# ----------------------------------

ctrl + alt + left  : komorebic focus left
ctrl + alt + down  : komorebic focus down
ctrl + alt + up    : komorebic focus up
ctrl + alt + right : komorebic focus right

# ----------------------------------
# Move Windows
# alt + cmd + arrows
# ----------------------------------

alt + lwin + left  : komorebic move left
alt + lwin + down  : komorebic move down
alt + lwin + up    : komorebic move up
alt + lwin + right : komorebic move right

# ----------------------------------
# Float
# alt + t
# ----------------------------------

alt + t : komorebic toggle-float

# ----------------------------------
# Monocle / Fullscreen
# alt + f
# ----------------------------------

alt + f : komorebic toggle-monocle

# ----------------------------------
# Promote Window
# ----------------------------------

alt + enter : komorebic promote

# ----------------------------------
# Resize Windows
# Similar to yabai resize
# ----------------------------------

alt + shift + left  : komorebic resize-axis horizontal decrease
alt + shift + right : komorebic resize-axis horizontal increase

alt + shift + up    : komorebic resize-axis vertical decrease
alt + shift + down  : komorebic resize-axis vertical increase

# ----------------------------------
# Stack Management
# ----------------------------------

alt + left  : komorebic stack left
alt + down  : komorebic stack down
alt + up    : komorebic stack up
alt + right : komorebic stack right

alt + ; : komorebic unstack

alt + [ : komorebic cycle-stack previous
alt + ] : komorebic cycle-stack next

# ----------------------------------
# Cycle Window Focus
# ----------------------------------

alt + shift + [ : komorebic cycle-focus previous
alt + shift + ] : komorebic cycle-focus next

# ----------------------------------
# Layout Manipulation
# ----------------------------------

alt + x : komorebic flip-layout horizontal
alt + y : komorebic flip-layout vertical

# ----------------------------------
# Workspaces
# ----------------------------------

alt + 1 : komorebic focus-workspace 0
alt + 2 : komorebic focus-workspace 1
alt + 3 : komorebic focus-workspace 2
alt + 4 : komorebic focus-workspace 3
alt + 5 : komorebic focus-workspace 4
alt + 6 : komorebic focus-workspace 5

# ----------------------------------
# Move To Workspace
# Follows Focus
# ----------------------------------

alt + shift + 1 : komorebic move-to-workspace 0
alt + shift + 2 : komorebic move-to-workspace 1
alt + shift + 3 : komorebic move-to-workspace 2
alt + shift + 4 : komorebic move-to-workspace 3
alt + shift + 5 : komorebic move-to-workspace 4
alt + shift + 6 : komorebic move-to-workspace 5

# ----------------------------------
# Monitor Focus
# Similar to yabai display focus
# ----------------------------------

ctrl + alt + [ : komorebic cycle-focus-monitor previous
ctrl + alt + ] : komorebic cycle-focus-monitor next

# ----------------------------------
# Move Window To Monitor
# ----------------------------------

ctrl + win + [ : komorebic cycle-move-to-monitor previous
ctrl + win + ] : komorebic cycle-move-to-monitor next

# ----------------------------------
# Retile
# ----------------------------------

alt + shift + r : komorebic retile

# ----------------------------------
# Pause WM
# ----------------------------------

alt + p : komorebic toggle-pause

# ----------------------------------
# Close Window
# ----------------------------------

alt + q : komorebic close

# ----------------------------------
# Launch Terminal
# cmd+shift+return
# ----------------------------------

win + shift + enter : wt

# ----------------------------------
# Firefox
# cmd+shift+f
# ----------------------------------

win + shift + f : start firefox

# ----------------------------------
# Lock Screen
# cmd+shift+l
# ----------------------------------

win + shift + l : rundll32.exe user32.dll,LockWorkStation